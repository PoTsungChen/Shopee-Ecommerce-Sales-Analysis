	column 'Age Range' =
			
			SWITCH(TRUE(),
			    dim_customers[Age] < 20, "< 20",
			    dim_customers[Age] <= 30, "20-30",
			    dim_customers[Age] <= 40, "30-40",
			    dim_customers[Age] <= 50, "40-50",
			    dim_customers[Age] <= 60, "50-60",
			    dim_customers[Age] <= 70, "60-70",
			    "70+"
			)
		lineageTag: d87eb8a6-0f05-4718-97b2-0d1c74fb3a2a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

