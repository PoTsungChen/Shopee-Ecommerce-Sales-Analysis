	measure 'Number of campaigns' = count(fct_orders[CAMPAIGN_ID])
		formatString: 0
		displayFolder: _measures
		lineageTag: 42922aa4-8be7-48cb-99da-f4fac168ab73

	measure Funnel_Starts =
			
			CALCULATE(
			    DISTINCTCOUNT(dim_sessions[ACTIVITY_ID]),
			    dim_sessions[event_page] = "Home page"
			)
		formatString: 0
		displayFolder: _measures
		lineageTag: 752fc644-957e-4a36-b50c-1c28aafd4cd5

	measure Funnel_final =
			
			CALCULATE(
			    DISTINCTCOUNT(dim_sessions[ACTIVITY_ID]),
			    dim_sessions[event_page] = "Payments"
			)
		formatString: 0
		displayFolder: _measures
		lineageTag: 19ebbeed-3000-428c-aef5-803dbf935645

	measure 'Conversion rate' = ```
			
			    DIVIDE([Funnel_final], [Funnel_Starts], 0)
			```
		formatString: 0%;-0%;0%
		displayFolder: _measures
		lineageTag: b937e5e4-184d-463d-9a40-5428ae99ace2

