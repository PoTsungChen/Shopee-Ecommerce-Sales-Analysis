table dim_customers
	lineageTag: 1b286f34-dfa5-4174-a826-2de5320d940b

	measure AOV = ```
			
			    sum(fct_orders[Total Sales]) / count(fct_orders[ORDER_ID])
			```
		displayFolder: _measures
		lineageTag: d37dd113-c936-4ba3-97d5-fdfced869ead

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales YoY%' =
			
			VAR __PREV_YEAR =
				CALCULATE(
					SUM('fct_orders'[Total Sales]),
					DATEADD('dim_date'[Date], -1, YEAR)
				)
			RETURN
				DIVIDE(SUM('fct_orders'[Total Sales]) - __PREV_YEAR, __PREV_YEAR)
		formatString: 0%;-0%;0%
		displayFolder: _measures
		lineageTag: c5f399bb-a8de-4165-8f96-66644724251d

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "YearOverYear"
				}

		changedProperty = FormatString

	measure 'Total Sales QoQ%' =
			
			VAR __PREV_QUARTER =
				CALCULATE(
					SUM('fct_orders'[Total Sales]),
					DATEADD('dim_date'[Date], -1, QUARTER)
				)
			RETURN
				DIVIDE(SUM('fct_orders'[Total Sales]) - __PREV_QUARTER, __PREV_QUARTER)
		formatString: 0%;-0%;0%
		displayFolder: _measures
		lineageTag: ec785fde-254a-42aa-a66a-7a8ab5ee0dd0

		extendedProperty MeasureTemplate =
