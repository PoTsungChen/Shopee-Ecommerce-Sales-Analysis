	measure 'Number of Orders YoY%' =
			
			VAR __PREV_YEAR =
				CALCULATE(
					COUNTA('fct_orders'[ORDER_ID]),
					DATEADD('dim_date'[Date], -1, YEAR)
				)
			RETURN
				DIVIDE(COUNTA('fct_orders'[ORDER_ID]) - __PREV_YEAR, __PREV_YEAR)
