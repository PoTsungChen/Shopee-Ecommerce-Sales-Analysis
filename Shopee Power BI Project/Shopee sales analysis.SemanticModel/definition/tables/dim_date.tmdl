	partition dim_date = calculated
		mode: import
		source = ```
				
				VAR StartDate = DATE(2021, 1, 1) -- Set your start year
				VAR EndDate = DATE(2025, 12, 31) -- Set your end year
				RETURN
				ADDCOLUMNS(
				    CALENDAR(StartDate, EndDate),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Month Name", FORMAT([Date], "MMMM"),
				    "Month Number", MONTH([Date]),
				    "Day", DAY([Date]),                    -- The 1-31 number
				    "Day Name", FORMAT([Date], "dddd"),             -- Monday, Tuesday...
				    "Day of Week Num", WEEKDAY([Date], 2),          -- 1 (Mon) to 7 (Sun)
				    "Is Weekend", IF(WEEKDAY([Date], 2) > 5, "Yes", "No")
				)
				
				```

	annotation PBI_Id = c9d9964c81324b7aa7a30b2690831c8d

